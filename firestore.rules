
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LIBRARY ACCESS CONTROL RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin check: 
    // 1. Explicitly defined in the roles_admin collection
    // 2. OR possesses a valid institutional email domain (bootstrap/prototype access)
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (request.auth.token.email != null && request.auth.token.email.matches('^.*@neu\\.edu\\.ph$'))
      );
    }

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /userProfiles/{userId} {
      // Allow list and get for everyone to support finding profiles by institutional email during library entry
      allow list, get: if true;
      
      // Strict: Only admins can manage (add/edit/delete) user profiles
      allow create, update, delete: if isAdmin();
    }

    match /visitLogs/{visitLogId} {
      // Admins have full access to view and manage logs
      allow get, list, update, delete: if isAdmin();
      
      // Anyone can create a visit log (visitors checking in)
      allow create: if true; 
    }

  }
}
