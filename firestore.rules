
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LIBRARY ACCESS CONTROL RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin/Staff check: 
    // Users with an institutional email are granted administrative access to manage logs and profiles.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email != null && 
        request.auth.token.email.matches('^.*@neu\\.edu\\.ph$')
      );
    }

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /userProfiles/{userId} {
      // Publicly allowed to list and get to support email verification during library entry
      allow list, get: if true;
      
      // Only admins/staff can manage user profiles
      allow create, update, delete: if isAdmin();
    }

    match /visitLogs/{visitLogId} {
      // Only admins and staff can view the complete visitor log and dashboard statistics
      allow get, list, update, delete: if isAdmin();
      
      // Publicly allowed to create a log entry (visitors checking in)
      allow create: if true; 
    }

  }
}
