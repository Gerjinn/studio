
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LIBRARY ACCESS CONTROL RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Staff/Admin check: 
    // 1. Users with @neu.edu.ph email are automatically staff
    // 2. Users explicitly added to roles_admin are admins
    function isStaff() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.matches('^.*@neu\\.edu\\.ph$')) ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isStaff();
    }

    match /userProfiles/{userId} {
      // Publicly allowed to list and get to support email verification during library entry
      allow list, get: if true;
      
      // Only staff can manage user profiles
      allow create, update, delete: if isStaff();
    }

    match /visitLogs/{visitLogId} {
      // Staff can view and manage logs
      allow get, list, update, delete: if isStaff();
      
      // Publicly allowed to create a log entry (visitors checking in)
      allow create: if true; 
    }

  }
}
