
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LIBRARY ACCESS CONTROL RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Staff/Admin check: 
    // Uses the roles_admin collection (DBAC model) for Authorization Independence.
    // Also allows the master bootstrap account via direct email check.
    function isStaff() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'gerjinn.yallung@neu.edu.ph'
      );
    }

    match /roles_admin/{adminUid} {
      // Users can check their own admin status
      allow get: if isSignedIn();
      // Only existing staff can list or manage staff roles
      allow list, create, update, delete: if isStaff();
    }

    match /userProfiles/{userId} {
      // Publicly allowed to list and get to support email verification during library entry
      allow list, get: if true;
      
      // Only staff can manage user profiles
      allow create, update, delete: if isStaff();
    }

    match /visitLogs/{visitLogId} {
      // Staff can view and manage logs
      allow get, list, update, delete: if isStaff();
      
      // Publicly allowed to create a log entry (visitors checking in)
      allow create: if true; 
    }

  }
}
