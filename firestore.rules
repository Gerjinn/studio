
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LIBRARY ACCESS CONTROL RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A robust check for admin status: 
    // 1. Explicitly defined in the roles_admin collection
    // 2. OR possesses a valid institutional email domain
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (request.auth.token.email != null && request.auth.token.email.matches('^.*@neu\\.edu\\.ph$'))
      );
    }

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow self-registration as admin for users with institutional emails
      allow create: if isSignedIn() && request.auth.uid == adminUid && request.auth.token.email.matches('^.*@neu\\.edu\\.ph$');
      allow update: if isAdmin() && request.auth.uid == adminUid;
      allow delete: if false;
    }

    match /userProfiles/{userId} {
      // Allow get and list for anyone to support searching for institutional emails during library entry
      allow get, list: if true;
      
      // Allow creation/updates only by the owner or an admin
      allow create, update: if isOwner(userId) || isAdmin();
      
      allow delete: if isAdmin();
    }

    match /visitLogs/{visitLogId} {
      // Allow listing and reading if the user is an admin
      allow get, list: if isAdmin();
      
      // Allow creation for visitors (students/employees logging their visit)
      allow create: if true; 
      
      allow update, delete: if isAdmin();
    }

  }
}
